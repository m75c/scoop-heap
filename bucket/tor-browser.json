{
    "##": "Multiple components under various open source licenses. Included HTTPS Everywhere extension is the strictest.",
    "version": "15.0.19",
    "description": "Web browser that connects to the internet via the Tor anonymity network",
    "homepage": "https://www.torproject.org/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://archive.torproject.org/tor-package-archive/torbrowser/15.0.19/tor-browser-windows-x86_64-portable-15.0.19.exe#/installer.exe",
            "hash": "0d4cc3a7b734a10c500217fb0df89452ee39185709193966831677bbd43c98f8"
        },
        "32bit": {
            "url": "https://archive.torproject.org/tor-package-archive/torbrowser/15.0.19/tor-browser-windows-i686-portable-15.0.19.exe#/installer.exe",
            "hash": "6464e941baf60d5ba47fdd4fc3ef208bd0ae0bdb29fbd6a12591164dea4b7f34"
        }
    },
    "pre_install": [
        "$installerFile=\"$dir\\installer.exe\"",
        "$tempDir=\"$dir\\_temp\"",
        "# Extract as 7-Zip archive",
        "Expand-7zipArchive -Path $installerFile -DestinationPath $tempDir",
        "# Move Browser dir to app dir",
        "movedir \"$tempDir\\Browser\" \"$dir\" | Out-Null",
        "# Update extensions in persisted profile",
        "movedir \"$dir\\TorBrowser\\Data\\Browser\\profile.default\" \"$persist_dir\\TorBrowser\\Data\\Browser\\profile.default\" | Out-Null",
        "# Remove temp files",
        "Remove-Item -Force -Recurse -Path $tempDir, $installerFile"
    ],
    "persist": [
        "TorBrowser\\Data\\Browser\\profile.default",
        "TorBrowser\\Data\\Tor"
    ],
    "bin": [
        [
            "firefox.exe",
            "tor-browser"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Tor Browser"
        ]
    ],
    "checkver": {
        "url": "https://www.torproject.org/download/",
        "regex": "torbrowser/([\\d.]+)/tor-browser-windows-x86_64-portable"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.torproject.org/tor-package-archive/torbrowser/$version/tor-browser-windows-x86_64-portable-$version.exe#/installer.exe"
            },
            "32bit": {
                "url": "https://archive.torproject.org/tor-package-archive/torbrowser/$version/tor-browser-windows-i686-portable-$version.exe#/installer.exe"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sums-signed-build.txt"
        }
    }
}
